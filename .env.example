# MongoDB bağlantı adresi (Atlas veya yerel)
MONGODB_URI="mongodb+srv://kullanici:sifre@cluster.mongodb.net/anka-emlak"

# Admin paneli giriş şifresi
ADMIN_PASSWORD="degistir-bu-sifreyi"
# Oturum token'ı için ayrı secret (opsiyonel; verilmezse ADMIN_PASSWORD kullanılır)
ADMIN_SESSION_SECRET="rastgele-uzun-bir-deger"

# Cloudinary (görsel yükleme)
CLOUDINARY_CLOUD_NAME="cloud-adiniz"
CLOUDINARY_API_KEY="api-key"
CLOUDINARY_API_SECRET="api-secret"
